#!/usr/bin/env bash
# Block commits that contain secrets. Wired via `git config core.hooksPath .githooks`.
set -euo pipefail

if command -v gitleaks >/dev/null 2>&1; then
  # gitleaks >= 8.19: `gitleaks git --staged` is the pre-commit scan.
  gitleaks git --staged --redact --no-banner .
else
  echo "CRITICAL: gitleaks not installed. Commit blocked." >&2
  echo "Install with: brew install gitleaks" >&2
  exit 1
fi
