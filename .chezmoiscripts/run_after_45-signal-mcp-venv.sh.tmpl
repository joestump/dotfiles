#!/usr/bin/env bash
# Pull signal-mcp to HEAD and warm its uv venv (Linux only).
#
# The Signal MCP is launched with `uv run --directory ~/src/signal-mcp`. The
# chezmoi external refreshes the clone on a 168h period, but `czu` runs more
# often than that — so we fetch + ff-only pull here on EVERY apply to get the
# absolute latest. Then we run `uv sync` to keep the venv in sync with whatever
# pyproject.toml changed.
#
# On macOS this is Joe's own dev checkout of signal-mcp, so we never touch it.
set -euo pipefail
{{- if ne .chezmoi.os "darwin" }}
repo="$HOME/src/signal-mcp"
# uv installs to ~/.local/bin; chezmoi may run from a shell that hasn't sourced it.
export PATH="$HOME/.local/bin:$PATH"

# Clean progress via the shared UI lib (spinner/ticks on a TTY, quiet lines
# otherwise); fallback keeps the script working if the lib hasn't been applied yet.
. "$HOME/.config/dotfiles/ui-lib.sh" 2>/dev/null || {
  have() { command -v "$1" >/dev/null 2>&1; }
  step() { shift; [ "${1:-}" = "--" ] && shift; "$@"; }
  heading() { printf '\n== %s ==\n' "$*"; }
  item() { shift; echo "    - $*"; }
  warn() { echo "  WARN: $*" >&2; }
}

heading "💬 Signal MCP"
[ -d "$repo/.git" ] || { item dim "no local checkout yet — skipping"; exit 0; }

# Aggressively fetch + ff-only pull on every apply. This clone is managed (nothing
# is developed here), so this is always safe.
if git -C "$repo" fetch --quiet --prune origin 2>/dev/null; then
  if git -C "$repo" merge --ff-only --quiet origin/main 2>/dev/null; then
    head="$(git -C "$repo" rev-parse --short HEAD)"
    item ok "signal-mcp at ${head}"
  else
    warn "ff-only merge failed (local commits?) — running from current HEAD"
  fi
else
  warn "fetch failed — running from current local state"
fi

# Keep the venv in sync with pyproject.toml after the pull.
have uv || { item dim "uv absent — skipping venv sync"; exit 0; }

if ! step "syncing uv venv" -- uv sync --directory "$repo" --quiet; then
  warn "uv sync failed; first launch may cold-start"
fi
{{- else }}
:  # macOS: signal-mcp is a dev checkout — leave it alone.
{{- end }}
