#!/usr/bin/env bash
# Warm the Signal MCP's uv venv (Linux only) so the FIRST Claude launch doesn't
# cold-resolve `mcp` + its transitive deps and overrun the MCP init window — the
# same class of slow-first-start we warm away for gitea-mcp via go-tools.txt.
#
# Runs on every apply (cheap: a directory test once warm). On macOS this is Joe's
# own dev checkout of signal-mcp, so we never touch its venv.
set -euo pipefail
{{- if ne .chezmoi.os "darwin" }}
repo="$HOME/src/signal-mcp"
# uv installs to ~/.local/bin; chezmoi may run from a shell that hasn't sourced it.
export PATH="$HOME/.local/bin:$PATH"

# Clean progress via the shared UI lib (spinner/ticks on a TTY, quiet lines
# otherwise); fallback keeps the script working if the lib hasn't been applied yet.
. "$HOME/.config/dotfiles/ui-lib.sh" 2>/dev/null || {
  have() { command -v "$1" >/dev/null 2>&1; }
  step() { shift; [ "${1:-}" = "--" ] && shift; "$@"; }
  heading() { printf '\n== %s ==\n' "$*"; }
  item() { shift; echo "    - $*"; }
  warn() { echo "  WARN: $*" >&2; }
}

heading "💬 Signal MCP"
have uv        || { item dim "uv absent — skipping venv warm"; exit 0; }
[ -d "$repo" ] || { item dim "no local checkout yet — skipping venv warm"; exit 0; }

if [ -d "$repo/.venv" ]; then
  item ok "venv already warm"
elif ! step "warming uv venv" -- uv sync --directory "$repo"; then
  warn "uv sync failed; first Claude launch may cold-start"
fi
{{- else }}
:  # macOS: signal-mcp is a dev checkout — leave its venv alone.
{{- end }}
