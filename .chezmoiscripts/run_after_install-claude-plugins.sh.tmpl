#!/usr/bin/env bash
# Keep Claude Code plugins (claude-plugins.tsv) installed AND current.
#
# Runs on EVERY apply (cheap when nothing changed: one `claude plugin list`).
# Why not run_onchange? New skills pushed to the private Gitea marketplace don't
# change the tsv, so an onchange gate would never re-fire and the skills would
# never propagate.
#
# Propagation model:
#   • LOCAL-PATH marketplace (the Gitea one, cloned by a chezmoi external):
#     fingerprinted by the clone's git HEAD. When HEAD moves we REINSTALL —
#     because authors don't always bump the plugin `version`, and
#     `claude plugin update` is a no-op when the version is unchanged (that's
#     exactly why a freshly-added skill silently failed to appear).
#   • REMOTE (GitHub) marketplaces: install-once; update with `claude plugin update`.
#
# The clone itself is refreshed by the chezmoi external (refreshPeriod). For an
# immediate pull+propagate after pushing skills: `chezmoi apply --refresh-externals`.
set -euo pipefail

command -v claude >/dev/null 2>&1 || { echo "claude CLI absent; skipping plugins"; exit 0; }
LIST="$HOME/.config/dotfiles/claude-plugins.tsv"
[ -f "$LIST" ] || { echo "no claude-plugins.tsv; skipping"; exit 0; }
STATE="$HOME/.config/dotfiles/.claude-plugin-state"; mkdir -p "$STATE"

installed="$(claude plugin list 2>/dev/null || true)"

echo "==> Claude plugins"
while read -r src plugin _rest; do
  case "$src" in ''|\#*) continue ;; esac
  [ -n "${plugin:-}" ] || continue
  src="${src/#\~/$HOME}"                              # expand a leading ~
  mp="${plugin##*@}"                                  # marketplace name (after @)
  sentinel="$STATE/${plugin//[^A-Za-z0-9_.@-]/_}"

  # Fingerprint local-path marketplaces by git HEAD; remote ones have no local
  # .git so head stays empty (install-once).
  head=""
  [ -d "$src/.git" ] && head="$(git -C "$src" rev-parse HEAD 2>/dev/null || true)"

  if ! grep -qF "$plugin" <<<"$installed"; then
    echo "  installing $plugin (marketplace: $src)"
    claude plugin marketplace add "$src" 2>/dev/null || claude plugin marketplace update "$mp" 2>/dev/null || true
    if claude plugin install "$plugin"; then printf '%s' "$head" >"$sentinel"; else echo "  WARN: install $plugin failed"; fi
  elif [ -n "$head" ] && [ "$head" != "$(cat "$sentinel" 2>/dev/null || true)" ]; then
    echo "  refreshing $plugin (local marketplace moved to ${head:0:7})"
    claude plugin marketplace update "$mp" 2>/dev/null || true
    claude plugin uninstall "$plugin" 2>/dev/null || true
    if claude plugin install "$plugin"; then printf '%s' "$head" >"$sentinel"; else echo "  WARN: refresh $plugin failed"; fi
  else
    echo "  $plugin present"
  fi
done < "$LIST"
