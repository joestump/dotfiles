#!/usr/bin/env bash
# Merge the shared MCP server set into Claude Desktop's config.
# Reruns when the base defs or lib change:
# base hash: {{ include "dot_config/dotfiles/mcp-servers.json" | sha256sum }}
# lib  hash: {{ include "dot_config/dotfiles/mcp-merge-lib.sh" | sha256sum }}
set -euo pipefail

# Shared UI lib (ticked items on a TTY, quiet lines otherwise) — sourced BEFORE
# mcp-merge-lib so its status lines render as items. Fallback keeps us working if
# the lib hasn't been applied yet.
. "$HOME/.config/dotfiles/ui-lib.sh" 2>/dev/null || {
  heading() { printf '\n== %s ==\n' "$*"; }
  item() { shift; echo "    - $*"; }
  warn() { echo "  WARN: $*" >&2; }
}
. "$HOME/.config/dotfiles/mcp-merge-lib.sh"

DC="$HOME/Library/Application Support/Claude/claude_desktop_config.json"
heading "🔗 Claude Desktop MCP"
[ -f "$DC" ] || { item dim "no Claude Desktop config — skipping"; exit 0; }

GT="$(mcp_secret gitea    GITEA_TOKEN                  "$(jq -r '.mcpServers.gitea.env.GITEA_ACCESS_TOKEN // ""'        "$DC")")"
# github is the REMOTE hosted GitHub MCP, reached via the npx mcp-remote bridge with
# a PAT Bearer (no Docker). Fallback extracts the prior token from the bridge's
# --header arg (ltrimstr no-ops on a bare pre-migration env value).
GH="$(mcp_secret github   GITHUB_PERSONAL_ACCESS_TOKEN "$(jq -r '(([.mcpServers.github.args[]?] | map(select(startswith("Authorization:Bearer ")))[0]) // .mcpServers.github.env.GITHUB_PERSONAL_ACCESS_TOKEN // "") | ltrimstr("Authorization:Bearer ")' "$DC")")"
KK="$(mcp_secret karakeep KARAKEEP_API_KEY             "$(jq -r '.mcpServers.karakeep.env.KARAKEEP_API_KEY // ""'      "$DC")")"
# Desktop is GUI-launched (no shell env to inherit), so outline's Bearer token is
# baked here at apply time — read straight from the Vault-Agent-rendered secrets
# (path-agnostic). Never written to the chezmoi repo.
OT="$( . "$HOME/.config/vault/secrets-static.env" >/dev/null 2>&1; printf '%s' "${OUTLINE_API_TOKEN:-}" )"

# signal is OS-specific (uv path + env PATH differ by OS; repo dir is ~/src/signal-mcp).
# Claude Desktop only exists on macOS/Windows, so in practice this is the macOS branch,
# but resolve per-OS for correctness. The daemon (tcp 127.0.0.1:7583) is launchd-run.
{{- if eq .chezmoi.os "darwin" }}
SIG_UV="{{ (lookPath "uv") | default "/opt/homebrew/bin/uv" }}"
SIG_PATH="/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin"
{{- else }}
SIG_UV="{{ .chezmoi.homeDir }}/.local/bin/uv"
SIG_PATH="{{ .chezmoi.homeDir }}/.local/bin:/usr/bin:/bin:/usr/local/bin"
{{- end }}
SIG_DIR="{{ .chezmoi.homeDir }}/src/signal-mcp"

# Claude Desktop entries carry NO "type" field; outline uses the npx mcp-remote stdio
# bridge with a STATIC Bearer header (no OAuth, no refresh tokens to expire).
desired="$(mcp_base | jq \
  --arg gt "$GT" --arg gh "$GH" --arg kk "$KK" --arg ot "$OT" \
  --arg uv "$SIG_UV" --arg sigdir "$SIG_DIR" --arg sigpath "$SIG_PATH" '
    (if $gt != "" then .gitea.env.GITEA_ACCESS_TOKEN = $gt else . end)
  | (if $kk != "" then .karakeep.env.KARAKEEP_API_KEY = $kk else . end)
  # github: REMOTE hosted MCP via the mcp-remote stdio bridge + PAT Bearer (no Docker).
  # Only set when the token resolved non-empty (dotfiles#15).
  | (if $gh != "" then .github = {command:"npx", args:["-y","mcp-remote","https://api.githubcopilot.com/mcp/",
                                     "--header", ("Authorization:Bearer " + $gh)]} else . end)
  | (if $ot != "" then .outline = {command:"npx", args:["-y","mcp-remote","https://outline.stump.rocks/mcp",
                                      "--header", ("Authorization:Bearer " + $ot)]} else . end)
  # signal: thin JSON-RPC client launched via uv; paths resolved per-OS above.
  | .signal = {command:$uv,
               args:["run","--directory",$sigdir,"signal-mcp","--account","{{ env "SIGNAL_MCP_ACCOUNT" | default .signalNumber }}","--operator","{{ env "SIGNAL_MCP_OPERATOR" | default .signalNumber }}","--transport","stdio"],
               env:{PATH:$sigpath}}
')"

mcp_merge "$DC" "$desired"
