#!/usr/bin/env bash
# Ensure every Claude Code plugin in claude-plugins.tsv is installed. Runs AFTER
# files/externals are applied (the Gitea marketplace is cloned by a chezmoi
# external first). Sentinel-gated per plugin (idempotent). Reruns when the list
# changes. Stay in sync separately with `claude plugin update`.
#
# list hash: {{ include "dot_config/dotfiles/claude-plugins.tsv" | sha256sum }}
set -euo pipefail

command -v claude >/dev/null 2>&1 || { echo "claude CLI absent; skipping plugins"; exit 0; }
LIST="$HOME/.config/dotfiles/claude-plugins.tsv"
[ -f "$LIST" ] || { echo "no claude-plugins.tsv; skipping"; exit 0; }

echo "==> Claude plugins"
while read -r src plugin _rest; do
  case "$src" in ''|\#*) continue ;; esac
  [ -n "${plugin:-}" ] || continue
  src="${src/#\~/$HOME}"                          # expand a leading ~
  if claude plugin list 2>/dev/null | grep -qF "$plugin"; then
    echo "  $plugin present"
  else
    echo "  installing $plugin (marketplace: $src)"
    claude plugin marketplace add "$src" || { echo "  WARN: could not add marketplace $src"; continue; }
    claude plugin install "$plugin" || echo "  WARN: failed to install $plugin"
  fi
done < "$LIST"
