#!/usr/bin/env bash
# Merge the shared MCP server set into Claude Code (~/.claude.json).
# Reruns when the base defs or lib change:
# base hash: {{ include "dot_config/dotfiles/mcp-servers.json" | sha256sum }}
# lib  hash: {{ include "dot_config/dotfiles/mcp-merge-lib.sh" | sha256sum }}
set -euo pipefail

# Shared UI lib (ticked items on a TTY, quiet lines otherwise) — sourced BEFORE
# mcp-merge-lib so its status lines render as items. Fallback keeps us working if
# the lib hasn't been applied yet.
. "$HOME/.config/dotfiles/ui-lib.sh" 2>/dev/null || {
  heading() { printf '\n== %s ==\n' "$*"; }
  item() { shift; echo "    - $*"; }
  warn() { echo "  WARN: $*" >&2; }
}
. "$HOME/.config/dotfiles/mcp-merge-lib.sh"

CJ="$HOME/.claude.json"
heading "🔗 Claude Code MCP"
[ -f "$CJ" ] || { item dim "no ~/.claude.json — skipping"; exit 0; }

# github + karakeep + outline tokens are baked here at apply time (from OpenBao).
# github is the REMOTE hosted GitHub MCP (api.githubcopilot.com) — native http with
# a PAT Bearer, exactly like outline: no Docker, no local runtime. karakeep is the
# npm @karakeep/mcp via npx (no Docker). gitea needs NO token in the config: it
# inherits GITEA_ACCESS_TOKEN from the launching shell (env.zsh) — nothing
# gitea-related lands in ~/.claude.json beyond GITEA_HOST.
# Fallbacks read the prior value from its current home (github → Bearer header;
# ltrimstr is a no-op on a bare token, so a pre-migration env value also passes).
GH="$(mcp_secret github   GITHUB_PERSONAL_ACCESS_TOKEN "$(jq -r '(.mcpServers.github.headers.Authorization // .mcpServers.github.env.GITHUB_PERSONAL_ACCESS_TOKEN // "") | ltrimstr("Bearer ")' "$CJ")")"
KK="$(mcp_secret karakeep KARAKEEP_API_KEY             "$(jq -r '.mcpServers.karakeep.env.KARAKEEP_API_KEY // ""'      "$CJ")")"
# outline is native http (not a subprocess), so it can't inherit the shell env, and
# Claude Code doesn't expand ${VAR} in http headers — so bake the Bearer token at
# apply time from the Vault-Agent-rendered secrets (like github/karakeep). The token
# never lands in the chezmoi repo.
OT="$( . "$HOME/.config/vault/secrets-static.env" >/dev/null 2>&1; printf '%s' "${OUTLINE_API_TOKEN:-}" )"

# signal is OS-specific: the uv binary path and env PATH differ macOS vs Linux; the
# repo dir is ~/src/signal-mcp on both (Joe's dev checkout on the Mac, a chezmoi
# external clone on Linux). Resolve those here. The daemon it talks to (tcp
# 127.0.0.1:7583) is supervised by launchd (macOS) / systemd --user (Linux).
{{- if eq .chezmoi.os "darwin" }}
SIG_UV="/opt/homebrew/bin/uv"
SIG_PATH="/opt/homebrew/bin:/usr/bin:/bin:/usr/sbin:/sbin"
{{- else }}
SIG_UV="{{ .chezmoi.homeDir }}/.local/bin/uv"
SIG_PATH="{{ .chezmoi.homeDir }}/.local/bin:/usr/bin:/bin:/usr/local/bin"
{{- end }}
SIG_DIR="{{ .chezmoi.homeDir }}/src/signal-mcp"

desired="$(mcp_base | jq \
  --arg gh "$GH" --arg kk "$KK" --arg ot "$OT" \
  --arg uv "$SIG_UV" --arg sigdir "$SIG_DIR" --arg sigpath "$SIG_PATH" '
    .karakeep.env.KARAKEEP_API_KEY             = $kk
  | map_values(. + {type:"stdio"})                              # Claude Code uses an explicit type
  # github: REMOTE hosted MCP — native http + PAT Bearer (no Docker / local runtime).
  | .github = {type:"http", url:"https://api.githubcopilot.com/mcp/",
               headers:{"Authorization": ("Bearer " + $gh)}}
  # outline: native http + a STATIC Bearer token (no OAuth/refresh tokens), baked.
  | .outline = {type:"http", url:"https://outline.stump.rocks/mcp",
                headers:{"Authorization": ("Bearer " + $ot)}}
  # signal: thin JSON-RPC client launched via uv; paths resolved per-OS above.
  | .signal = {type:"stdio", command:$uv,
               args:["run","--directory",$sigdir,"server","--user-id","{{ .signalNumber }}","--transport","stdio"],
               env:{PATH:$sigpath}}
')"

mcp_merge "$CJ" "$desired"
