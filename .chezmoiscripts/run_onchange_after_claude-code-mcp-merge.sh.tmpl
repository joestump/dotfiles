#!/usr/bin/env bash
# Merge the shared MCP server set into Claude Code (~/.claude.json).
# Reruns when the base defs or lib change:
# base hash: {{ include "dot_config/dotfiles/mcp-servers.json" | sha256sum }}
# lib  hash: {{ include "dot_config/dotfiles/mcp-merge-lib.sh" | sha256sum }}
set -euo pipefail

. "$HOME/.config/dotfiles/mcp-merge-lib.sh"
CJ="$HOME/.claude.json"
[ -f "$CJ" ] || { echo "no ~/.claude.json; skipping"; exit 0; }
echo "==> Claude Code mcpServers merge"

# github + karakeep tokens are baked here at apply time (from OpenBao). gitea needs
# NO token in the config: gitea-mcp inherits GITEA_ACCESS_TOKEN from the shell that
# Claude Code is launched from (exported in ~/.oh-my-zsh/custom/env.zsh). So nothing
# gitea-related is ever written to ~/.claude.json beyond GITEA_HOST.
GH="$(mcp_secret github   GITHUB_PERSONAL_ACCESS_TOKEN "$(jq -r '.mcpServers.github.env.GITHUB_PERSONAL_ACCESS_TOKEN // ""' "$CJ")")"
KK="$(mcp_secret karakeep KARAKEEP_API_KEY             "$(jq -r '.mcpServers.karakeep.env.KARAKEEP_API_KEY // ""'      "$CJ")")"
# outline is native http (not a subprocess), so it can't inherit the shell env, and
# Claude Code doesn't expand ${VAR} in http headers — so bake the Bearer token at
# apply time from the Vault-Agent-rendered secrets (like github/karakeep). The token
# never lands in the chezmoi repo.
OT="$( . "$HOME/.config/vault/secrets-static.env" >/dev/null 2>&1; printf '%s' "${OUTLINE_API_TOKEN:-}" )"

desired="$(mcp_base | jq --arg gh "$GH" --arg kk "$KK" --arg ot "$OT" '
    .github.env.GITHUB_PERSONAL_ACCESS_TOKEN   = $gh
  | .karakeep.env.KARAKEEP_API_KEY             = $kk
  | map_values(. + {type:"stdio"})                              # Claude Code uses an explicit type
  # outline: native http + a STATIC Bearer token (no OAuth/refresh tokens), baked.
  | .outline = {type:"http", url:"https://outline.stump.rocks/mcp",
                headers:{"Authorization": ("Bearer " + $ot)}}
{{- if ne .chezmoi.os "darwin" }}
  | del(.signal)   # signal-cli daemon (+ uv/signal-cli) is macOS-only
{{- end }}
')"

mcp_merge "$CJ" "$desired"
{{- if ne .chezmoi.os "darwin" }}

# signal is macOS-only (signal-cli daemon + uv). mcp_merge preserves existing
# servers, so explicitly drop any stale signal entry on Linux. Idempotent.
if jq -e '.mcpServers.signal' "$CJ" >/dev/null 2>&1; then
  t="$(mktemp)" && jq 'del(.mcpServers.signal)' "$CJ" > "$t" && chmod 600 "$t" && mv "$t" "$CJ" \
    && echo "  $CJ: dropped macOS-only signal server"
fi
{{- end }}
