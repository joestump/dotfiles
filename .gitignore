# NEVER commit secrets or real local env files. Secrets come from OpenBao at
# runtime (see examples/envrc.example), not from files in this repo.
.env
.env.*
*.local
.envrc
!examples/*.example
.direnv/

# Claude Code local settings (machine-specific overrides; not portable)
.claude/settings.local.json

# chezmoi local state / OS cruft
.DS_Store
chezmoistate.boltdb

# Docusaurus build output (the pages workflow builds this; never commit it)
/dist/
