# Repo-only files: present in the source repo, never applied to $HOME.
README.md
Architecture.md
CLAUDE.md
docs/
examples/
scripts/
test/

# Oh My Zsh self-manages its own tree and self-updates it. chezmoi must manage
# ONLY ~/.oh-my-zsh/custom/. Use non-recursive '*' here: gitignore semantics
# forbid re-including children of a fully-excluded directory, so excluding
# '.oh-my-zsh/**' would also swallow custom/. Excluding only the direct children
# lets us re-include the custom/ dir below.
.oh-my-zsh/*
!.oh-my-zsh/custom/
# OMZ ships this example; leave it to OMZ, don't manage it.
.oh-my-zsh/custom/example.zsh
website/
dist/

# Vim runtime state — installed by vim-plug (~/.vim/plugged/) or created by vim
# itself (undo/backup/swap in ~/.local/state/vim/). chezmoi manages ~/.vimrc and
# the plug.vim external only.
.vim/plugged/
.vim/.netrwhist
.viminfo
.local/state/vim/

# OS-specific Vault Agent supervisor: launchd LaunchAgent on macOS, systemd
# --user service on Linux. Ignore the one that doesn't apply to this machine.
{{ if ne .chezmoi.os "darwin" -}}
Library/
{{ end -}}
{{ if ne .chezmoi.os "linux" -}}
.config/systemd/
{{ end -}}
