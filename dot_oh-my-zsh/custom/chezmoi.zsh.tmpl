# Dotfiles convenience helpers.

# czu — bring this machine fully current in one step:
#   1. chezmoi update        → git pull + apply the latest config
#   2. vault-agent restart   → re-render secrets from OpenBao now (don't wait ~5m)
#   3. exec zsh              → reload the shell so new config + secrets take effect
# Extra args pass through to chezmoi update (e.g. `czu --refresh-externals`).
#
# The actual logic lives in czu-run.sh so the SAME implementation backs both an
# interactive `czu` and the scheduled czu timer/launchd job (every 6h, headless) —
# see dot_config/dotfiles/executable_czu-run.sh. This wrapper just adds the
# `exec zsh` reload, which only makes sense in an interactive shell.
czu() {
  emulate -L zsh
  "$HOME/.config/dotfiles/czu-run.zsh" "$@" || return
  # No footer line: the all-✓ sections already say "up to date", and the fresh MOTD +
  # prompt after `exec zsh` are the natural "done, new shell" signal.
  [[ -o interactive ]] && exec zsh
}

# czinit <host> — bootstrap a fresh node end-to-end over SSH, in one command:
#   1. seed the node's git credential store with your Gitea token (piped over
#      stdin — never in argv), so the private dotfiles repo can clone;
#   2. install chezmoi from get.chezmoi.io and run `chezmoi init --apply`;
#   3. log in to OpenBao via OIDC (vault-login: tunnel + login + agent kick) so
#      secrets render. You just click Authorize in the browser when it opens.
#   e.g.  czinit joestump@ie02.stump.rocks
czinit() {
  emulate -L zsh
  local host=$1
  [[ -z $host ]] && { print -u2 "usage: czinit <host>   e.g. czinit joestump@ie02.stump.rocks"; return 2 }
  local repo="https://gitea.stump.rocks/{{ .githubUser }}/dotfiles.git"

  # Resolve a Gitea token locally to seed the node (env, then rendered secrets).
  local tok="${GITEA_TOKEN:-}"
  [[ -z $tok && -r ~/.config/vault/secrets-static.env ]] && \
    tok="$( . ~/.config/vault/secrets-static.env >/dev/null 2>&1; printf '%s' "${GITEA_TOKEN:-}" )"
  [[ -z $tok ]] && { print -u2 "czinit: no GITEA_TOKEN locally — run 'vault-oidc-login' first."; return 1 }

  print -u2 "→ seeding Gitea credentials on ${host} …"
  ssh "$host" 'umask 077; cat > ~/.git-credentials && git config --global credential."https://gitea.stump.rocks".helper store' \
    <<< "https://{{ .githubUser }}:${tok}@gitea.stump.rocks" \
    || { print -u2 "czinit: could not seed credentials on ${host}"; return 1 }

  print -u2 "→ installing chezmoi + applying dotfiles on ${host} (sudo may prompt) …"
  ssh -t "$host" "sh -c \"\$(curl -fsLS get.chezmoi.io)\" -- init --apply '${repo}'" \
    || { print -u2 "czinit: bootstrap failed on ${host}"; return 1; }

  # Provision the Vault Agent's machine identity so it renders secrets AND renews
  # itself forever — no interactive OIDC, no max-TTL death (dotfiles#1, OMG
  # 2026-07-01). czapprole mints a fresh secret_id from your (already authenticated)
  # laptop session and ships role_id+secret_id to the node; the agent takes it from
  # there. Falls back to the OIDC login path if AppRole can't be provisioned.
  if (( $+functions[czapprole] )); then
    print -u2 "→ provisioning AppRole machine identity on ${host} (self-renewing, no browser) …"
    czapprole "$host" \
      || print -u2 "czinit: AppRole step failed — run 'czapprole ${host}' later (or 'vault-login ${host}' for the OIDC fallback)."
  elif (( $+functions[vault-login] )); then
    print -u2 "→ authenticating to OpenBao (OIDC fallback) — click Authorize when the browser opens …"
    vault-login "$host" \
      || print -u2 "czinit: OIDC step skipped/failed — run 'vault-login ${host}' later to render secrets."
  else
    print -u2 "→ final step — run: czapprole ${host}"
  fi

  # Clean up bootstrap credentials: the node now has the host-scoped credential
  # helper from dot_config/git/config.tmpl (credential-gitea.sh reads the live
  # OpenBao token), so the seeded ~/.git-credentials and the temporary store
  # helper are no longer needed (dotfiles#13).
  ssh "$host" 'rm -f ~/.git-credentials; git config --global --unset credential."https://gitea.stump.rocks".helper 2>/dev/null; true' \
    || print -u2 "czinit: credential cleanup failed on ${host} (non-fatal)."

  print -u2 "\n✓ ${host} bootstrapped — dotfiles applied and Vault Agent provisioned (self-renewing)."
}
