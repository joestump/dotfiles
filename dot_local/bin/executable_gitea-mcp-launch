#!/usr/bin/env bash
# gitea-mcp launcher — managed by chezmoi.
#
# Resolves the Gitea token at RUNTIME from the Vault Agent (never baked into
# ~/.claude.json or the repo, and fresh across rotations), exports it as
# GITEA_ACCESS_TOKEN, then exec's whatever command follows (e.g.
# `go run gitea.com/gitea/gitea-mcp@latest -t stdio`).
#
# Token sources, in order: already-exported $GITEA_TOKEN → the agent-rendered
# secrets file → `vault kv get`. The secrets file is sourced in a SUBSHELL so only
# the Gitea token reaches the MCP process, not every other secret.
set -euo pipefail

token="${GITEA_TOKEN:-}"

if [ -z "$token" ] && [ -r "$HOME/.config/vault/secrets-static.env" ]; then
  token="$( . "$HOME/.config/vault/secrets-static.env" >/dev/null 2>&1; printf '%s' "${GITEA_TOKEN:-}" )"
fi

if [ -z "$token" ] && command -v vault >/dev/null 2>&1; then
  token="$(VAULT_ADDR="${VAULT_ADDR:-https://vault.stump.rocks}" \
           vault kv get -field=GITEA_TOKEN secret/personal/gitea 2>/dev/null || true)"
fi

export GITEA_ACCESS_TOKEN="$token"
export GITEA_HOST="${GITEA_HOST:-https://gitea.stump.rocks}"

# gitea-mcp runs via `go run`; make sure `go` is resolvable even under Claude
# Code's (possibly minimal) PATH.
for d in /usr/local/go/bin "$HOME/go/bin" /opt/homebrew/bin; do
  case ":$PATH:" in *":$d:"*) ;; *) [ -d "$d" ] && PATH="$d:$PATH" ;; esac
done
export PATH

exec "$@"
