# Vault Agent config — managed by chezmoi (source: dot_config/vault/agent.hcl.tmpl).
# Runs continuously under launchd (macOS) / systemd --user (Linux): authenticates,
# renews, and re-renders the secrets files on a schedule / on secret change.
#
# The brace expressions below are resolved by chezmoi at `chezmoi apply` (they
# fill in your home dir). The Consul-Template logic lives in the *.ctmpl files.
#
# AUTH MODE is chosen at apply time by whether an AppRole secret-id has been
# provisioned on this host:
#
#   ~/.config/vault/approle/secret-id EXISTS  ->  method "approle"  (self-renewing
#       machine identity — periodic token + non-expiring secret_id, so the agent
#       re-authenticates FOREVER with no human. Provisioned by `czapprole <host>`
#       or `czinit`.)  This is the durable design (OMG 2026-07-01 / dotfiles#1).
#
#   otherwise  ->  method "token_file"  (legacy: you `vault login -method=oidc`
#       once; the agent renews that token until its max-TTL, then it DIES with no
#       way to re-auth. Kept only as the pre-provisioning fallback so a fresh host
#       still renders secrets before AppRole is wired up.)

pid_file = "{{ .chezmoi.homeDir }}/.config/vault/agent.pid"

vault {
  address = "https://vault.stump.rocks"
}

{{ $approleSecretId := joinPath .chezmoi.homeDir ".config/vault/approle/secret-id" -}}
{{ if stat $approleSecretId -}}
auto_auth {
  # AppRole: self-renewing machine identity. role_id + secret_id live in files
  # (0600) provisioned by `czapprole`/`czinit` from an authenticated laptop. The
  # agent logs in, gets a periodic token it renews forever, and re-logs-in with
  # role_id+secret_id if the token is ever lost. No human, no max-TTL cliff.
  method "approle" {
    mount_path = "auth/approle"
    config = {
      role_id_file_path                   = "{{ .chezmoi.homeDir }}/.config/vault/approle/role-id"
      secret_id_file_path                 = "{{ .chezmoi.homeDir }}/.config/vault/approle/secret-id"
      # MUST stay false — the agent re-reads secret-id to re-authenticate.
      remove_secret_id_file_after_reading = false
    }
  }

  sink "file" {
    config = {
      path = "{{ .chezmoi.homeDir }}/.config/vault/agent-token"
      mode = 0600
    }
  }

  # Mirror the token to the CLI's default location so bare `vault` commands (and
  # anything that reads ~/.vault-token) ride the self-renewing AppRole identity
  # instead of a stale interactive OIDC token (dotfiles#1 follow-up). Only on the
  # AppRole path — the token_file path below already authenticates FROM this file.
  # Note: while this sink is active a plain `vault login -method=oidc` won't stick
  # (the agent overwrites it); pause the agent (`vault-agent stop`) for a genuine
  # full-OIDC session.
  sink "file" {
    config = {
      path = "{{ .chezmoi.homeDir }}/.vault-token"
      mode = 0600
    }
  }
}
{{ else -}}
auto_auth {
  # token_file (legacy fallback): you run `vault login -method=oidc` once; the
  # agent reads that token from ~/.vault-token, uses it, and keeps it renewed.
  # It CANNOT re-authenticate — at the token's max-TTL it dies. Provision AppRole
  # (`czapprole <host>`) to get a self-renewing agent instead.
  method "token_file" {
    config = {
      token_file_path = "{{ .chezmoi.homeDir }}/.vault-token"
    }
  }

  sink "file" {
    config = {
      path = "{{ .chezmoi.homeDir }}/.config/vault/agent-token"
      mode = 0600
    }
  }
}
{{ end -}}

# Keep running and retrying even if a template can't render yet (e.g. the AWS
# secrets engine isn't configured during initial bring-up).
template_config {
  exit_on_retry_failure = false
  static_secret_render_interval = "5m"
}

# Static KV secrets (LLM keys, Gitea, Pocket ID, Garage).
template {
  source      = "{{ .chezmoi.homeDir }}/.config/vault/secrets-static.env.ctmpl"
  destination = "{{ .chezmoi.homeDir }}/.config/vault/secrets-static.env"
  perms       = "0600"
}

# Dynamic, short-lived AWS credentials (auto-rotated on lease expiry). Renders
# empty when the user has no secret/users/$USER/aws — a harmless empty env file,
# so no gating is needed.
template {
  source      = "{{ .chezmoi.homeDir }}/.config/vault/secrets-aws.env.ctmpl"
  destination = "{{ .chezmoi.homeDir }}/.config/vault/secrets-aws.env"
  perms       = "0600"
}

# SSH keys rendered as FILES. Source of truth = OpenBao secret/users/$USER/ssh.
# ssh-keys.ctmpl auto-discovers EVERY field of that bag and writeToFile()s each to
# ~/.ssh/<field> (0600, or 0644 for *.pub) — the file-secret analogue of the static
# env bag. No per-key config, no gating: a user with no ssh bag writes nothing under
# ~/.ssh (only the manifest below), so it can never clobber a key. The destination
# is a names-only manifest of what was written.
template {
  source      = "{{ .chezmoi.homeDir }}/.config/vault/ssh-keys.ctmpl"
  destination = "{{ .chezmoi.homeDir }}/.config/vault/ssh-keys.manifest"
  perms       = "0600"
}
