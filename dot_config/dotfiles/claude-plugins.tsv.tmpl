# Claude Code plugins to ensure installed. One per line:
#   <marketplace-add source>  <plugin>@<marketplace-name>
# Whitespace-separated; # comments allowed. The marketplace source may be a
# GitHub owner/repo, a full git URL (e.g. Gitea), or a local path.
# Add a line + `chezmoi apply` to install it everywhere (the run_after script keeps
# them current). To update one by hand: `claude plugin update <plugin>@<marketplace>`
# (e.g. `claude plugin update qmd@qmd`) — there is no bulk "update all" form.
# GitHub marketplaces add directly by owner/repo. The private Gitea one is a
# LOCAL PATH (chezmoi external clones it to ~/.config/claude-marketplaces/).
tobi/qmd                                       qmd@qmd
{{ .githubUser }}/claude-plugin-sdd                     sdd@claude-plugin-sdd
{{ .githubUser }}/claude-skills                         claude-skills@{{ .githubUser }}
stump-wtf/claude-plugin-switchboard            switchboard@claude-plugin-switchboard
~/.config/claude-marketplaces/claude-personal  personal@claude-personal
