# shellcheck shell=bash
# Shared "send a Signal note-to-self from a non-interactive script" helper — for
# anything running under launchd/systemd --user that needs to alert Joe without
# going through Claude. Used by vault-agent-stale.sh (dead-auth alert) and
# czu-run.sh (scheduled-sync failure alert). Source this, then call `notify "msg"`.
#
# Tries the warm signal-cli daemon first (JSON-RPC on 127.0.0.1:7583 — fast, no
# cold JVM start), falls back to a cold signal-cli send, then to syslog as a last
# resort so the failure is at least discoverable.
SIGNAL_NUMBER="{{ env "SIGNAL_MCP_USER_ID" | default .signalNumber }}"

_signal_have() { command -v "$1" >/dev/null 2>&1; }

# Uses python3 for a BOUNDED socket exchange — raw `nc` half-closes and hangs on
# BSD/macOS because the daemon keeps the connection open. Returns 0 only on a
# JSON-RPC result.
_signal_send_via_daemon() {
  _signal_have python3 || return 1
  python3 - "$SIGNAL_NUMBER" "$1" <<'PY'
import socket, json, sys
num, msg = sys.argv[1], sys.argv[2]
try:
    s = socket.create_connection(("127.0.0.1", 7583), timeout=5)
    s.settimeout(8)
    s.sendall((json.dumps({"jsonrpc":"2.0","method":"send",
        "params":{"recipient":[num],"message":msg},"id":1})+"\n").encode())
    buf = b""
    while b"\n" not in buf:
        chunk = s.recv(4096)
        if not chunk:
            break
        buf += chunk
    s.close()
    for line in buf.decode(errors="replace").splitlines():
        try:
            d = json.loads(line)
        except ValueError:
            continue
        if d.get("id") == 1:
            sys.exit(0 if "result" in d else 1)
    sys.exit(1)
except Exception:
    sys.exit(1)
PY
}

notify() {
  local msg="$1"
  # 1) warm signal-cli daemon — fast, no cold JVM.
  _signal_send_via_daemon "$msg" && return 0
  # 2) cold signal-cli send (note-to-self) — reliable where the daemon isn't up.
  if _signal_have signal-cli; then
    signal-cli -a "$SIGNAL_NUMBER" send -m "$msg" "$SIGNAL_NUMBER" >/dev/null 2>&1 && return 0
  fi
  # 3) last resort so it is at least discoverable in the system log.
  _signal_have logger && logger -t signal-notify "$msg"
  return 1
}
