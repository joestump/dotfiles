# Ghostty config — managed by chezmoi (~/.config/ghostty/config; read on macOS + Linux).
# Reload in-app with Cmd+Shift+, (macOS). Docs: https://ghostty.org/docs/config

# Font — the Nerd Font you installed, so prompt glyphs render everywhere.
font-family = "MesloLGS Nerd Font"
font-size = 14

# Catppuccin Mocha: dark with soft pink/mauve accents (matches the pink prompt).
theme = "Catppuccin Mocha"

# Cursor — a blinking bar.
cursor-style = bar
cursor-style-blink = true

# Subtle frosted-glass background (macOS).
background-opacity = 0.96
background-blur = 20

# Roominess + restore your windows/tabs on relaunch.
window-padding-x = 12
window-padding-y = 8
window-save-state = always

# macOS niceties.
macos-titlebar-style = tabs
macos-option-as-alt = true

# Quality of life.
mouse-hide-while-typing = true
copy-on-select = clipboard

# No "close this surface? there are running processes" nag — zsh/tmux/etc. always
# look like "running processes" to the shell-integration check, and the confirm
# dialog fires on every tab close. Off.
confirm-close-surface = false

# SSH: auto-install Ghostty's terminfo on remote hosts (fixes "xterm-ghostty:
# unknown terminal type" + garbled input over SSH) and propagate a sane TERM.
# Same as the default feature set with ssh-env/ssh-terminfo flipped on.
shell-integration-features = cursor,no-sudo,title,ssh-env,ssh-terminfo,path
