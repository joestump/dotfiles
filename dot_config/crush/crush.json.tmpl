      "mcp_karakeep_get-bookmark-content",
      "mcp_karakeep_get-lists",
      "mcp_karakeep_get-list",
      "mcp_karakeep_get-tags",
      "mcp_karakeep_get-tag",
      "mcp_karakeep_get-tag-bookmarks",
      "mcp_chrome-devtools_list_pages",
      "mcp_chrome-devtools_list_console_messages",
      "mcp_chrome-devtools_list_network_requests",
      "mcp_chrome-devtools_get_network_request",
      "mcp_chrome-devtools_take_snapshot",
      "mcp_chrome-devtools_take_screenshot",
      "mcp_chrome-devtools_performance_analyze_insight",
      "mcp_aws-knowledge_aws___search_documentation",
      "mcp_aws-knowledge_aws___read_documentation",
      "mcp_aws-knowledge_aws___get_regional_availability",
      "mcp_aws-knowledge_aws___list_regions",
