# Managed by chezmoi. This is the XDG global git config (~/.config/git/config),
# read ALONGSIDE ~/.gitconfig — your identity/aliases there are untouched; on a
# key conflict ~/.gitconfig wins. Kept here so chezmoi never has to own your
# personal ~/.gitconfig.
#
# Host-scoped credential helper: supplies the Gitea token (from OpenBao via the
# Vault Agent) on demand, so private clones need no token in the URL:
#
#     git clone https://gitea.stump.rocks/joestump/claude-personal.git
#
[credential "https://gitea.stump.rocks"]
	# Empty value resets the helper list for this host, so inherited global
	# helpers (e.g. macOS osxkeychain) can't serve a STALE cached token after a
	# rotation. Only our helper — which always reads the live OpenBao token —
	# answers for Gitea, identically on macOS and Linux.
	helper = ""
	helper = {{ .chezmoi.homeDir }}/.config/git/credential-gitea.sh
