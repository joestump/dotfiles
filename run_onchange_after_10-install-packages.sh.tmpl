#!/usr/bin/env bash
# chezmoi run_onchange_ script: reruns when any manifest below changes (hashes
# embedded). Installs tooling per-OS — macOS via Homebrew/Brewfile, Linux via apt.
#
# Brewfile hash:   {{ include "dot_Brewfile" | sha256sum }}
# apt hash:        {{ include "dot_config/dotfiles/apt-packages.txt" | sha256sum }}
# go-tools hash:   {{ include "dot_config/dotfiles/go-tools.txt" | sha256sum }}
set -euo pipefail
OS="$(uname -s)"

# ---------------------------------------------------------------- macOS -------
ensure_vault_macos() {
  command -v vault >/dev/null 2>&1 && return 0
  brew tap hashicorp/tap >/dev/null 2>&1 || true
  brew trust hashicorp/tap >/dev/null 2>&1 || true
  brew trust --formula hashicorp/tap/vault >/dev/null 2>&1 || true
  brew install hashicorp/tap/vault || echo "WARN: brew install vault failed"
}

install_macos() {
  for p in /opt/homebrew/bin/brew /usr/local/bin/brew; do
    [ -x "$p" ] && eval "$("$p" shellenv)" && break
  done
  if command -v brew >/dev/null 2>&1 && [ -f "$HOME/.Brewfile" ]; then
    echo "==> brew bundle (~/.Brewfile)"
    brew bundle --global || echo "WARN: brew bundle had failures"
  fi
  ensure_vault_macos
}

# ---------------------------------------------------------------- Linux -------
ensure_gh_linux() {
  command -v gh >/dev/null 2>&1 && return 0
  echo "==> installing gh (GitHub apt repo)"
  sudo mkdir -p -m 755 /etc/apt/keyrings
  curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg \
    | sudo tee /etc/apt/keyrings/githubcli-archive-keyring.gpg >/dev/null
  sudo chmod go+r /etc/apt/keyrings/githubcli-archive-keyring.gpg
  echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" \
    | sudo tee /etc/apt/sources.list.d/github-cli.list >/dev/null
  sudo apt-get update -y && sudo apt-get install -y gh || echo "WARN: gh install failed"
}

ensure_vault_linux() {
  command -v vault >/dev/null 2>&1 && return 0
  echo "==> installing vault (HashiCorp apt repo)"
  curl -fsSL https://apt.releases.hashicorp.com/gpg \
    | sudo gpg --dearmor -o /usr/share/keyrings/hashicorp-archive-keyring.gpg
  echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/hashicorp-archive-keyring.gpg] https://apt.releases.hashicorp.com $(. /etc/os-release && echo "$VERSION_CODENAME") main" \
    | sudo tee /etc/apt/sources.list.d/hashicorp.list >/dev/null
  sudo apt-get update -y && sudo apt-get install -y vault || echo "WARN: vault install failed"
}

install_linux() {
  command -v apt-get >/dev/null 2>&1 || { echo "no apt-get; skipping Linux packages"; return 0; }
  local list="$HOME/.config/dotfiles/apt-packages.txt"
  local pkgs=()
  if [ -f "$list" ]; then
    while IFS= read -r p; do case "$p" in ''|\#*) ;; *) pkgs+=("$p") ;; esac; done < "$list"
  fi
  echo "==> apt-get install: ${pkgs[*]:-(none)}"
  sudo apt-get update -y
  if [ "${#pkgs[@]}" -gt 0 ]; then sudo apt-get install -y "${pkgs[@]}" || echo "WARN: some apt packages failed"; fi
  ensure_gh_linux
  ensure_vault_linux
}

case "$OS" in
  Darwin) install_macos ;;
  Linux)  install_linux ;;
esac

# ---- Go tools (either OS, only if `go` is present) ----
GO_TOOLS="$HOME/.config/dotfiles/go-tools.txt"
if command -v go >/dev/null 2>&1 && [ -f "$GO_TOOLS" ]; then
  echo "==> go install (from go-tools.txt)"
  while IFS= read -r mod; do
    case "$mod" in ''|\#*) continue ;; esac
    echo "   go install $mod"
    go install "$mod" || echo "   WARN: go install $mod failed"
  done < "$GO_TOOLS"
fi

echo "==> packages installed"
