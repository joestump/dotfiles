#!/usr/bin/env bash
# chezmoi run_onchange_ script: reruns when any manifest below changes (hashes
# embedded). Installs tooling per-OS — macOS via Homebrew/Brewfile, Linux via apt.
#
# Brewfile hash:   {{ include "dot_Brewfile" | sha256sum }}
# apt hash:        {{ include "dot_config/dotfiles/apt-packages.txt" | sha256sum }}
# go-tools hash:   {{ include "dot_config/dotfiles/go-tools.txt" | sha256sum }}
set -euo pipefail
OS="$(uname -s)"

# Pinned signal-cli version for Linux (macOS gets it from Homebrew). Bump this and
# `chezmoi apply` re-runs this script (run_onchange keys on its rendered content).
SIGNAL_CLI_VER="0.14.5"

# ---------------------------------------------------------------- macOS -------
ensure_vault_macos() {
  command -v vault >/dev/null 2>&1 && return 0
  brew tap hashicorp/tap >/dev/null 2>&1 || true
  brew trust hashicorp/tap >/dev/null 2>&1 || true
  brew trust --formula hashicorp/tap/vault >/dev/null 2>&1 || true
  brew install hashicorp/tap/vault || echo "WARN: brew install vault failed"
}

install_macos() {
  for p in /opt/homebrew/bin/brew /usr/local/bin/brew; do
    [ -x "$p" ] && eval "$("$p" shellenv)" && break
  done
  if command -v brew >/dev/null 2>&1 && [ -f "$HOME/.Brewfile" ]; then
    echo "==> brew bundle (~/.Brewfile)"
    brew bundle --global || echo "WARN: brew bundle had failures"
  fi
  ensure_vault_macos
}

# ---------------------------------------------------------------- Linux -------
ensure_gh_linux() {
  command -v gh >/dev/null 2>&1 && return 0
  echo "==> installing gh (GitHub apt repo)"
  sudo mkdir -p -m 755 /etc/apt/keyrings
  curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg \
    | sudo tee /etc/apt/keyrings/githubcli-archive-keyring.gpg >/dev/null
  sudo chmod go+r /etc/apt/keyrings/githubcli-archive-keyring.gpg
  echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" \
    | sudo tee /etc/apt/sources.list.d/github-cli.list >/dev/null
  sudo apt-get update -y && sudo apt-get install -y gh || echo "WARN: gh install failed"
}

ensure_vault_linux() {
  command -v vault >/dev/null 2>&1 && return 0
  echo "==> installing vault (HashiCorp apt repo)"
  curl -fsSL https://apt.releases.hashicorp.com/gpg \
    | sudo gpg --dearmor -o /usr/share/keyrings/hashicorp-archive-keyring.gpg
  echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/hashicorp-archive-keyring.gpg] https://apt.releases.hashicorp.com $(. /etc/os-release && echo "$VERSION_CODENAME") main" \
    | sudo tee /etc/apt/sources.list.d/hashicorp.list >/dev/null
  sudo apt-get update -y && sudo apt-get install -y vault || echo "WARN: vault install failed"
}

# uv — Python runner that launches the Signal MCP (`uv run --directory ~/src/signal-mcp`).
# Astral's installer drops it in ~/.local/bin; NO_MODIFY_PATH so it never edits the
# chezmoi-managed shell rc (PATH already includes ~/.local/bin via env.zsh/.profile).
ensure_uv_linux() {
  command -v uv >/dev/null 2>&1 && return 0
  [ -x "$HOME/.local/bin/uv" ] && return 0
  echo "==> installing uv (astral installer → ~/.local/bin)"
  curl -LsSf https://astral.sh/uv/install.sh | env INSTALLER_NO_MODIFY_PATH=1 sh \
    || echo "WARN: uv install failed"
}

# signal-cli — the JVM Signal client the daemon (systemd --user signal-daemon) runs.
# Not in apt; install the generic release tarball (needs the JRE from apt-packages)
# under ~/.local/opt and symlink ~/.local/bin/signal-cli. Arch-independent, so it
# works on future arm64 nodes too. Idempotent: skips when already at SIGNAL_CLI_VER.
ensure_signal_cli_linux() {
  local ver="$SIGNAL_CLI_VER"
  local dest="$HOME/.local/opt/signal-cli-$ver" link="$HOME/.local/bin/signal-cli"
  if [ -x "$dest/bin/signal-cli" ] && [ "$(readlink "$link" 2>/dev/null)" = "$dest/bin/signal-cli" ]; then
    return 0
  fi
  echo "==> installing signal-cli $ver (GitHub release tarball → ~/.local/opt)"
  local url="https://github.com/AsamK/signal-cli/releases/download/v${ver}/signal-cli-${ver}.tar.gz"
  local tmp; tmp="$(mktemp -d)"
  if curl -fsSL "$url" -o "$tmp/signal-cli.tar.gz"; then
    mkdir -p "$HOME/.local/opt" "$HOME/.local/bin"
    rm -rf "$dest"
    tar -xzf "$tmp/signal-cli.tar.gz" -C "$HOME/.local/opt"   # → signal-cli-<ver>/
    ln -sfn "$dest/bin/signal-cli" "$link"
    echo "   signal-cli $ver → $link (run 'signal-link' once to link this device)"
  else
    echo "WARN: could not download signal-cli $ver from $url"
  fi
  rm -rf "$tmp"
}

install_linux() {
  command -v apt-get >/dev/null 2>&1 || { echo "no apt-get; skipping Linux packages"; return 0; }
  local list="$HOME/.config/dotfiles/apt-packages.txt"
  local pkgs=()
  if [ -f "$list" ]; then
    while IFS= read -r p; do
      p="${p%%#*}"                          # strip inline/trailing comments
      p="${p#"${p%%[![:space:]]*}"}"        # ltrim
      p="${p%"${p##*[![:space:]]}"}"        # rtrim
      [ -n "$p" ] && pkgs+=("$p")           # skip blank/comment-only lines
    done < "$list"
  fi
  echo "==> apt-get install: ${pkgs[*]:-(none)}"
  sudo apt-get update -y
  if [ "${#pkgs[@]}" -gt 0 ]; then
    # A transient apt/network blip during bootstrap must not silently leave packages
    # missing — run_onchange won't retry on a stable hash. Retry once after a refresh.
    sudo apt-get install -y "${pkgs[@]}" \
      || { echo "apt install failed — refreshing indexes and retrying…"; sudo apt-get update -y; sudo apt-get install -y "${pkgs[@]}"; } \
      || echo "WARN: some apt packages still failed — install by hand, or re-run 'chezmoi apply --force'."
  fi
  ensure_gh_linux
  ensure_vault_linux
  ensure_uv_linux
  ensure_signal_cli_linux
}

# Claude Code CLI — install if absent (native installer → ~/.local/bin, versioned
# under ~/.local/share/claude). Cross-platform + idempotent. Must land before the
# claude-*-mcp-merge and plugin scripts that need `claude`; this script runs at "10",
# ahead of them.
ensure_claude() {
  export PATH="$HOME/.local/bin:$PATH"
  if command -v claude >/dev/null 2>&1 || [ -x "$HOME/.local/bin/claude" ]; then
    echo "claude CLI present"
  else
    echo "==> installing Claude Code CLI (native)"
    curl -fsSL https://claude.ai/install.sh | bash || echo "WARN: claude install failed"
  fi
  # The MCP merge scripts skip when ~/.claude.json is absent, and claude only creates
  # it on first run — seed an empty one so a fresh node's MCP config populates in the
  # same apply.
  [ -f "$HOME/.claude.json" ] || { echo '{}' > "$HOME/.claude.json" && chmod 600 "$HOME/.claude.json"; }
}

case "$OS" in
  Darwin) install_macos ;;
  Linux)  install_linux ;;
esac

ensure_claude

# ---- Go tools (either OS, only if `go` is present) ----
GO_TOOLS="$HOME/.config/dotfiles/go-tools.txt"
if command -v go >/dev/null 2>&1 && [ -f "$GO_TOOLS" ]; then
  echo "==> go install (from go-tools.txt)"
  while IFS= read -r mod; do
    case "$mod" in ''|\#*) continue ;; esac
    echo "   go install $mod"
    go install "$mod" || echo "   WARN: go install $mod failed"
  done < "$GO_TOOLS"
fi

echo "==> packages installed"
